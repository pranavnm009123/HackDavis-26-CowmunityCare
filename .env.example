GEMINI_API_KEY=your_gemini_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
MONGODB_URI=mongodb://localhost:27017/voicebridge

# Backboard RAG — optional but recommended for richer resource matching
# Get your API key at https://app.backboard.io
BACKBOARD_API_KEY=
# If you've created a Backboard assistant and synced yolo_resources.md to it:
BACKBOARD_ASSISTANT_ID=

# Email (Gmail) — for sending intake confirmations and resource emails to patients
# 1. Use any Gmail account (e.g. yourname@gmail.com)
# 2. Enable 2-Factor Authentication on that account
# 3. Go to myaccount.google.com → Security → App Passwords → generate one for "Mail"
# 4. Paste the 16-char app password (no spaces) below
# If not set, emails go to Ethereal (test inbox) and a preview URL is printed to console.
GMAIL_USER=
GMAIL_APP_PASSWORD=
